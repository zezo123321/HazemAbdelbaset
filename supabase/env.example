# Supabase Environment Variables
# Copy this file to the project root as .env.local
# Do NOT commit .env.local to version control.

# ─── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── Resend (Email) ──────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...your-resend-key
RESEND_TEST_TO=zakiziad9001_sd@med.bsu.edu.eg
RESEND_TEST_FROM=onboarding@resend.dev
CONTACT_EMAIL=info@hazemabdelbaset.studio
OWNER_FROM_EMAIL=Hazem Portfolio <info@hazemabdelbaset.studio>
CLIENT_FROM_EMAIL=Hazem Abdelbaset <info@hazemabdelbaset.studio>

# ─── Paymob (Payments) ───────────────────────────────────────
# Only needed if using the workshop payment system
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_HMAC=

# ─── Google (Calendar/OAuth) ─────────────────────────────────
# Only needed if using the booking + Google Calendar integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
